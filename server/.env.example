DATABASE_URL=postgres://feedmind:feedmind@localhost:5432/feedmind?sslmode=disable
FEEDMIND_JWT_SECRET=replace-with-at-least-32-random-characters
FEEDMIND_ADDR=:8080
FEEDMIND_MODE=all
FEEDMIND_LOG_LEVEL=info
# Docker Compose 日志轮转可通过 FEEDMIND_LOG_MAX_SIZE 和 FEEDMIND_LOG_MAX_FILES 调整。
FEEDMIND_WORKER_COUNT=8
# 可选：独立部署的 Cloudflare HTML Worker。生产环境填写其 HTTPS /html 地址，不要使用服务端 localhost。
# URL 与 Token 必须同时配置；Token 只供 Go 服务端使用，不得提供给客户端。
# Docker Compose 中访问宿主机本地 Worker 可填写 http://host.docker.internal:8787/html。
FEEDMIND_HTML_WORKER_URL=
FEEDMIND_HTML_WORKER_TOKEN=
FEEDMIND_HTML_WORKER_TIMEOUT=20s
FEEDMIND_HTML_WORKER_MAX_BYTES=8388608
FEEDMIND_PUBLIC_URL=http://localhost:8080
FEEDMIND_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
FEEDMIND_COOKIE_SECURE=false
# 留空 SMTP 主机时，邮件发送会失败，注册请求可在配置 SMTP 后重试。
FEEDMIND_SMTP_HOST=
FEEDMIND_SMTP_PORT=587
FEEDMIND_SMTP_USER=
FEEDMIND_SMTP_PASSWORD=
FEEDMIND_MAIL_FROM_NAME=FeedMind
FEEDMIND_MAIL_FROM_ADDRESS=
