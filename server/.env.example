DATABASE_URL=postgres://feedmind:feedmind@localhost:5432/feedmind?sslmode=disable
FEEDMIND_JWT_SECRET=replace-with-at-least-32-random-characters
FEEDMIND_ADDR=:8080
FEEDMIND_MODE=all
FEEDMIND_WORKER_COUNT=8
FEEDMIND_PUBLIC_URL=http://localhost:8080
FEEDMIND_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
FEEDMIND_COOKIE_SECURE=false
# 留空 SMTP 主机时，验证/重置验证码仅输出到服务端日志（本地开发）。
FEEDMIND_SMTP_HOST=
FEEDMIND_SMTP_PORT=587
FEEDMIND_SMTP_USER=
FEEDMIND_SMTP_PASSWORD=
FEEDMIND_MAIL_FROM_NAME=FeedMind
FEEDMIND_MAIL_FROM_ADDRESS=
